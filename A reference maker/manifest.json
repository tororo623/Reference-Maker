{
  "manifest_version": 3,
  "name": "一発参考文献メーカー",
  "version": "1.0",
  "permissions": ["activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "generate-citation": {
      "suggested_key": {
        "default": "Ctrl+Shift+Z",
        "mac": "Command+Shift+Z"
      },
      "description": "参考文献フォーマットを作成してコピー"
    }
  }
}